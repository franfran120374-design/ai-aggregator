# Copie ce fichier en .env et remplis tes clés (toutes gratuites, sans CB)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optionnel, providers payants (jamais utilisés automatiquement)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optionnel : plafond mensuel $ pour les providers payants (défaut 5.0)
MAX_MONTHLY_SPEND_USD=

# Optionnel mais fortement recommandé dès que le serveur est exposé hors de ta machine
# (ex: via un tunnel) : un code d'accès partagé, généré par ex. avec
# python -c "import secrets; print(secrets.token_urlsafe(12))"
APP_ACCESS_TOKEN=
